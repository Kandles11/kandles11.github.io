---
interface Props {
  date: string | Date;
  title: string;
  time: string;
  location?: string;
  description?: string;
  organizer?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  date,
  title,
  time,
  location,
  description,
  organizer,
  ctaLabel,
  ctaHref
} = Astro.props;

const parseCalendarDate = (value: string | Date): Date => {
  if (value instanceof Date) {
    return value;
  }

  // Interpret YYYY-MM-DD as a local calendar date to avoid UTC day-shift.
  const localDateMatch = /^(\d{4})-(\d{2})-(\d{2})$/.exec(value);
  if (localDateMatch) {
    const year = Number(localDateMatch[1]);
    const month = Number(localDateMatch[2]);
    const day = Number(localDateMatch[3]);
    return new Date(year, month - 1, day);
  }

  return new Date(value);
};

const parsedDate = parseCalendarDate(date);
const hasValidDate = !Number.isNaN(parsedDate.getTime());
const monthLabel = hasValidDate
  ? parsedDate
      .toLocaleDateString("en-US", { month: "short" })
      .toUpperCase()
  : "DATE";
const dayLabel = hasValidDate
  ? parsedDate.toLocaleDateString("en-US", { day: "numeric" })
  : "--";
const weekdayLabel = hasValidDate
  ? parsedDate.toLocaleDateString("en-US", { weekday: "short" })
  : "";
---

<section class="calendar-invite" aria-label="Calendar invite card">
  <div class="date-tile" aria-hidden="true">
    <div class="month">{monthLabel}</div>
    <div class="day">{dayLabel}</div>
    {weekdayLabel && <div class="weekday">{weekdayLabel}</div>}
  </div>

  <div class="details">
    <p class="eyebrow">Calendar Invite</p>
    <h3>{title}</h3>
    <p class="meta"><strong>When:</strong> {time}</p>
    {location && <p class="meta"><strong>Where:</strong> {location}</p>}
    {organizer && <p class="meta"><strong>Organizer:</strong> {organizer}</p>}
    {description && <p class="description">{description}</p>}
    {ctaLabel && ctaHref && (
      <a class="cta" href={ctaHref}>
        {ctaLabel}
      </a>
    )}
  </div>
</section>

<style>
  .calendar-invite {
    position: relative;
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 14px;
    align-items: center;
    margin: 16px 0 18px;
    padding: 14px;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: linear-gradient(180deg, var(--surface) 0%, var(--surface-soft) 100%);
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.1);
  }

  .calendar-invite::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, rgba(77, 109, 255, 0.35), rgba(239, 68, 68, 0.25));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .date-tile {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    text-align: center;
    font-weight: 700;
    box-shadow: 0 4px 14px rgba(15, 23, 42, 0.08);
    align-self: start;
  }

  .month {
    background: linear-gradient(180deg, #f85a5a 0%, #ef4444 100%);
    color: #fff;
    font-size: 12px;
    letter-spacing: 0.9px;
    padding: 7px 8px;
  }

  .day {
    color: var(--text);
    font-size: 38px;
    line-height: 1;
    padding-top: 9px;
  }

  .weekday {
    color: var(--muted);
    font-size: 12px;
    font-weight: 600;
    padding: 4px 8px 10px;
  }

  .eyebrow {
    margin: 0 0 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .details h3 {
    margin: 0 0 6px;
    font-size: 1.15rem;
    line-height: 1.3;
    color: var(--text);
  }

  .details {
    display: grid;
    gap: 4px;
    align-content: center;
  }

  .details p {
    margin: 0;
    line-height: 1.3;
  }

  .meta {
    margin: 0;
    color: var(--subtle-text);
    font-size: 0.95rem;
  }

  .meta strong {
    color: var(--text);
  }

  .description {
    margin: 2px 0 0;
    color: var(--subtle-text);
  }

  .cta {
    display: inline-block;
    margin-top: 10px;
    padding: 8px 12px;
    border-radius: 10px;
    background: rgba(77, 109, 255, 0.14);
    color: var(--link);
    border: 1px solid rgba(77, 109, 255, 0.25);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .cta:hover {
    background: rgba(77, 109, 255, 0.22);
    transform: translateY(-1px);
  }

  @media (prefers-color-scheme: dark) {
    .calendar-invite {
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.45);
    }

    .calendar-invite::before {
      background: linear-gradient(135deg, rgba(143, 178, 255, 0.5), rgba(248, 90, 90, 0.4));
    }

    .month {
      background: linear-gradient(180deg, #ff6b6b 0%, #ef4444 100%);
    }
  }

  @media (max-width: 640px) {
    .calendar-invite {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 14px;
    }

    .date-tile {
      width: 92px;
    }
  }
</style>
