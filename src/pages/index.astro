---
import Base from "../layouts/Base.astro";
import HeroDemo from "../components/HeroDemo.astro";
---

<Base title="Mason Thomas">
  <main>
    <div class="skip-nav" style="padding-top: 116px"></div>
    <div class="hero">
      <div class="ambient-lights">
        <div class="light"></div>
      </div>
      <div class="text-content fadeIn">
        <h1><span>Hey,</span> <span>I'm Mason,</span> <span>and I deliver</span> <br /><span>full-stack solutions</span></h1>
        <h2>
          <span>Whether it's frontend or backend, I have <br /> the skills to make your
          vision a reality.</span>
        </h2>
      </div>
      <div class="demo">
        <div class="frame fall-in">
          <HeroDemo image="chesspage.png" />
        </div>
        <div class="frame fall-in">
          <HeroDemo image="robopage.png" />
        </div>
        <div class="frame fall-in">
          <HeroDemo image="assetpage.png" />
        </div>
      </div>
    </div>
  </main>
</Base>

<style>
  main {
    color: white;
  }

  .hero {
    height: 100vh;
  }
  h1 {
    padding: 0;
    margin-top: 20px;
    font-size: 3.3rem;
    font-weight: 510;
    line-height: 1.1;
  }

  .fadeIn span{
  opacity: 0;
  filter: blur(12px);
  transform: translateX(-20px) translateY(30px);
  animation: fadeIn 1s ease-out forwards;
  display:inline-block;
}

.fadeIn span:nth-of-type(1){
  animation-delay: .8s;
}

.fadeIn span:nth-of-type(2){
  animation-delay: .9s;
}

.fadeIn span:nth-of-type(3){
  animation-delay: 1.0s;
}

.fadeIn span:nth-of-type(4){
  animation-delay: 1.1s;
}

.fadeIn h2 span {
  animation-delay: 1.2s;
}


@keyframes fadeIn{
  to{
	filter: blur(0px);
    opacity: 1;
    transform: translateX(0) translateY(0);
  }
}

  h2 {
    opacity: 0.7;
    font-size: 21px;
    font-weight: 480;
    letter-spacing: -0.37px;
  }

  .hero {
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .text-content {
    margin: 20px auto; /* Adjust this value as needed */
    padding: 0;
    width: 50%;
  }

  .demo {
    margin: 0 auto; /* Adjust this value as needed */
    padding: 0;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .frame {
    transform-style: preserve-3d;
    transform: rotatex(22deg) rotate(-14deg) rotatey(17deg) translatez(var(--z));
    box-shadow: -30px 70px 150px -20px rgba(51, 51, 51, 0.25);
    position: absolute;
    width: 45%;
    overflow: hidden;
    animation: fall-in 2s ease-out none;
    transition: transform 0.5s ease-in-out;
  }

  .frame:nth-child(1) {
    top: 5%;
    left: 25%;
    z-index: 1;
    --z: 30px;
  }

  .frame:nth-child(2) {
    top: 10%;
    left: 45%;
    z-index: 2;
    --z: 50px;
  }

  .frame:nth-child(3) {
    top: 15%;
    left: 10%;
    --z: -20px;
  }
  
  .frame:nth-child(1):hover {
    --z: 80px;
    transition: transform 0.5s ease-in-out;
  }

  .frame:nth-child(2):hover {
    --z: 100px;
    transition: transform 0.5s ease-in-out;
  }

  .frame:nth-child(3):hover {
    --z: 30px;
    transition: transform 0.5s ease-in-out;
  }

  @keyframes fall-in {
    from {
      opacity: 0;
      filter: blur(12px);
      animation-delay: 1s;
      transform: rotatex(22deg) rotate(-14deg) rotatey(17deg) translatez(300px);
    }
    to {
      opacity: 100;
      filter: blur(0px);
      transform: rotatex(22deg) rotate(-14deg) rotatey(17deg) translatez(var(--z));
    }
  }

  .ambient-lights {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .light {
    transform: translatey(-350px) rotate(-45deg);
    position: absolute;
    height: 1380px;
    width: 560px;
    color: white;
    background: radial-gradient(
      68.54% 68.72% at 55.02% 31.46%,
      hsla(0, 0%, 85%, 0.08) 0,
      hsla(0, 0%, 55%, 0.02) 50%,
      hsla(0, 0%, 45%, 0) 80%
    );
  }
</style>