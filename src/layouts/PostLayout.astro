---
import SiteLayout from "./SiteLayout.astro";

interface Frontmatter {
  title: string;
  date?: Date | string;
}

interface Props {
  frontmatter: Frontmatter;
}

const { frontmatter } = Astro.props;
const dateValue = frontmatter.date
  ? new Date(frontmatter.date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric"
    })
  : "";
---

<SiteLayout pageTitle={`${frontmatter.title} - Mason Thomas`}>
  <article class="article-content">
    <a href="/" class="home-link">← Home</a>
    <h1>{frontmatter.title}</h1>
    {dateValue && <p class="article-date">{dateValue}</p>}
    <slot />
  </article>
</SiteLayout>

<style>
  .home-link {
    display: inline-block;
    margin-bottom: 30px;
    color: #64748b;
    text-decoration: none;
    font-size: 15px;
  }

  .home-link:hover {
    color: #4d6dff;
  }

  .article-content {
    line-height: 1.7;
  }

  .article-content h1 {
    font-size: 2.5rem;
    margin: 0 0 15px;
    line-height: 1.2;
  }

  .article-date {
    font-size: 15px;
    color: #64748b;
    margin: 0 0 30px;
  }

  .article-content :global(h2) {
    font-size: 1.8rem;
    margin: 40px 0 20px;
    line-height: 1.3;
  }

  .article-content :global(h3) {
    font-size: 1.4rem;
    margin: 30px 0 15px;
  }

  .article-content :global(p) {
    margin: 0 0 20px;
    color: #334155;
  }

  .article-content :global(a) {
    text-decoration: none;
  }

  .article-content :global(a:hover) {
    text-decoration: underline;
  }

  .article-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 20px 0;
  }
</style>
