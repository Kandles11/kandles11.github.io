---
import SiteLayout from "./SiteLayout.astro";

interface Frontmatter {
  title: string;
  date?: Date | string;
}

interface Props {
  frontmatter: Frontmatter;
}

const { frontmatter } = Astro.props;
const dateValue = frontmatter.date
  ? new Date(frontmatter.date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric"
    })
  : "";
---

<SiteLayout pageTitle={`${frontmatter.title} - Mason Thomas`}>
  <article class="article-content">
    <a href="/" class="home-link">← Home</a>
    <h1>{frontmatter.title}</h1>
    {dateValue && <p class="article-date">{dateValue}</p>}
    <slot />
  </article>
</SiteLayout>

<style>
  .home-link {
    display: inline-block;
    margin-bottom: 30px;
    color: #64748b;
    text-decoration: none;
    font-size: 15px;
  }

  .home-link:hover {
    color: #4d6dff;
  }

  .article-content {
    line-height: 1.7;
  }

  .article-content h1 {
    font-size: 2.5rem;
    margin: 0 0 15px;
    line-height: 1.2;
  }

  .article-date {
    font-size: 15px;
    color: #64748b;
    margin: 0 0 30px;
  }

  .article-content :global(h2) {
    font-size: 1.8rem;
    margin: 40px 0 20px;
    line-height: 1.3;
  }

  .article-content :global(h3) {
    font-size: 1.4rem;
    margin: 30px 0 15px;
  }

  .article-content :global(p) {
    margin: 0 0 20px;
    color: #334155;
  }

  .article-content :global(a) {
    text-decoration: none;
  }

  .article-content :global(a:hover) {
    text-decoration: underline;
  }

  .article-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 20px 0;
  }

  .article-content :global(table) {
    width: max-content;
    max-width: 100%;
    margin: 24px auto;
    border-collapse: collapse;
    display: block;
    overflow-x: auto;
    white-space: nowrap;
  }

  .article-content :global(th),
  .article-content :global(td) {
    border: 1px solid #dbe3ef;
    padding: 8px 10px;
    text-align: left;
    vertical-align: top;
  }

  .article-content :global(th) {
    background: #f8fbff;
    font-weight: 600;
    color: #1f2a44;
  }

  .article-content :global(blockquote) {
    position: relative;
    margin: 30px 0;
    padding: 18px 22px 18px 52px;
    border-left: 3px solid #cbd5e1;
    background: #f8fafc;
    border-radius: 10px;
  }

  .article-content :global(blockquote::before) {
    content: "\201C";
    position: absolute;
    left: 12px;
    top: -14px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 64px;
    line-height: 1;
    color: #94a3b8;
    pointer-events: none;
  }

  .article-content :global(blockquote::after) {
    content: "\201D";
    position: absolute;
    right: 12px;
    bottom: -32px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 64px;
    line-height: 1;
    color: #cbd5e1;
    pointer-events: none;
  }

  .article-content :global(blockquote p) {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.08rem;
    line-height: 1.65;
    color: #334155;
    font-style: italic;
  }
</style>
